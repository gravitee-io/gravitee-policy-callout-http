{
    "id": "my-api-https",
    "name": "my-api-https",
    "gravitee": "2.0.0",
    "proxy": {
        "context_path": "/test-https",
        "endpoints": [
            {
                "name": "default",
                "target": "http://localhost:8080/endpoint",
                "http": {
                    "connectTimeout": 3000,
                    "readTimeout": 60000
                }
            }
        ]
    },
    "flows": [
        {
            "name": "flow-1",
            "methods": ["GET"],
            "enabled": true,
            "path-operator": {
                "path": "/",
                "operator": "STARTS_WITH"
            },
            "pre": [
                {
                    "name": "Callout HTTPS",
                    "description": "",
                    "enabled": true,
                    "policy": "policy-http-callout",
                    "configuration": {
                        "method": "GET",
                        "url": "${CALLOUT_HTTPS_URL}/callout",
                        "scope": "REQUEST",
                        "variables": [
                            {
                                "name": "calloutContent",
                                "value": "{#jsonPath(#calloutResponse.content, '$')}"
                            }
                        ]
                    }
                }
            ],
            "post": [
                {
                    "name": "Copy Callout Attribute",
                    "description": "",
                    "enabled": true,
                    "policy": "copy-callout-attribute",
                    "configuration": {}
                }
            ]
        }
    ]
}
