{
    "id": "proxy-request-callout-https",
    "name": "my-api",
    "gravitee": "4.0.0",
    "type": "proxy",
    "listeners": [
        {
            "type": "http",
            "paths": [
                {
                    "path": "/proxy-request-callout-https"
                }
            ],
            "entrypoints": [{ "type": "http-proxy" }]
        }
    ],
    "endpointGroups": [
        {
            "name": "default",
            "type": "http-proxy",
            "endpoints": [
                {
                    "name": "default-endpoint",
                    "type": "http-proxy",
                    "configuration": { "target": "http://localhost:8080/endpoint" }
                }
            ]
        }
    ],
    "flows": [
        {
            "name": "flow-1",
            "methods": [],
            "enabled": true,
            "path-operator": {
                "path": "/",
                "operator": "STARTS_WITH"
            },
            "request": [
                {
                    "name": "Callout HTTPS",
                    "description": "",
                    "enabled": true,
                    "policy": "policy-http-callout",
                    "configuration": {
                        "method": "GET",
                        "url": "${CALLOUT_HTTPS_URL}/callout",
                        "variables": [
                            {
                                "name": "newContent",
                                "value": "{#jsonPath(#calloutResponse.content, '$')}"
                            }
                        ]
                    }
                }
            ],
            "response": [
                {
                    "name": "Assign content",
                    "description": "",
                    "enabled": true,
                    "policy": "assign-content",
                    "configuration": {
                        "body": "new content: {#context.attributes['newContent']}"
                    }
                }
            ]
        }
    ]
}
